{
  "name": "@akryum/sheep",
  "version": "0.6.1",
  "description": "Opinionated CLI command to release and update CHANGELOG.md",
  "keywords": [
    "cli",
    "release",
    "changelog",
    "monorepo",
    "pnpm"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Akryum/sheep.git"
  },
  "license": "MIT",
  "author": {
    "name": "Guillaume Chau"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "sheep": "./bin.js"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsdown",
    "watch": "tsdown --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc",
    "release": "pnpm run build && pnpm run test && node ./dist/bin.js release -b main"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.11.30",
    "@types/prompts": "^2.0.14",
    "@types/semver": "^7.5.8",
    "changelogen": "^0.5.5",
    "execa": "^6.1.0",
    "fast-glob": "^3.2.11",
    "fs-extra": "^11.2.0",
    "pathe": "^1.1.2",
    "picocolors": "^1.0.0",
    "prompts": "^2.4.2",
    "sade": "^1.8.1",
    "semver": "^7.6.0",
    "tsdown": "^0.22.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "bin.js"
  ],
  "packageManager": "pnpm@11.1.1+sha512.d1fdf5f73c617b64fa1a56a81c3c8dfe0e966e33a6010aa256b517ae77be21d93e05affc0de1a83b0e4f29d569f68b446ae8f068cd7247c0bb3df0fb4d7bdf9a"
}
